{
  "version": 2,
  "buildCommand": "vite build",
  "outputDirectory": "dist/public",
  "functions": {
    "api/index.ts": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/manus-storage/:path*", "destination": "/api/index.ts" },
    { "source": "/api/:path*",           "destination": "/api/index.ts" },
    { "source": "/:path*",               "destination": "/index.html"   }
  ]
}
